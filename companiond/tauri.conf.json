{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CHRIS",
  "version": "0.1.0",
  "identifier": "dev.chris.companion",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "blob",
        "title": "CHRIS",
        "width": 180,
        "height": 200,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "center": false
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/icon.png"]
  }
}
